# SMTP (Gmail recommended — use an App Password, not your real Gmail password)
# How to get an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=you@gmail.com

# Where failure alert emails are sent
ALERT_EMAIL_TO=you@gmail.com
